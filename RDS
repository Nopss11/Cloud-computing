#!/bin/bash
# 1. SETUP LOGGING (Agar Anda bisa melihat prosesnya di AWS Console)
exec > >(tee /var/log/user-data.log|logger -t user-data -s 2>/dev/console) 2>&1

echo "=== Memulai konfigurasi Web Server dan Koneksi RDS ==="

# 2. UPDATE OS & INSTALASI PAKET
# Menginstal web server (Apache) dan PHP beserta modul MySQL
dnf update -y
dnf install -y httpd php php-mysqli

# 3. DEKLARASI VARIABEL DATABASE (Hardcoded)
# Silakan sesuaikan DB_HOST dengan Endpoint RDS Anda yang sebenarnya
DB_HOST="database-1.cf22a6isonvg.us-east-1.rds.amazonaws.com"
DB_USER="nopal"
DB_PASS="password_nopal_123"
DB_NAME="database_nopal"

# 4. MEMBUAT FILE APLIKASI WEB (PHP)
# Skrip ini akan membuat file index.php yang otomatis menggunakan variabel di atas
cat <<EOF > /var/www/html/index.php
<?php
// Mengambil data kredensial
\$host = "$DB_HOST";
\$user = "$DB_USER";
\$pass = "$DB_PASS";
\$db   = "$DB_NAME";

// Mencoba membuka koneksi ke Amazon RDS
\$conn = new mysqli(\$host, \$user, \$pass, \$db);

// Mengecek apakah koneksi berhasil atau gagal
if (\$conn->connect_error) {
    die("<h1 style='color:red;'>Koneksi ke RDS Gagal:</h1> <p>" . \$conn->connect_error . "</p>");
}

// Jika berhasil, tampilkan pesan ini di browser
echo "<h1>Halo Nopal! Web Server di EC2 Berhasil Menyala.</h1>";
echo "<p style='color:blue;'><b>Status: Koneksi ke Database RDS SUKSES!</b></p>";
echo "<p>Terkoneksi ke host: <i>\$host</i></p>";
?>
EOF

# Hapus index.html default bawaan Apache agar index.php kita yang terbaca
rm -f /var/www/html/index.html
chown -R apache:apache /var/www/html/

# 5. MENYALAKAN WEB SERVER
systemctl start httpd
systemctl enable httpd
