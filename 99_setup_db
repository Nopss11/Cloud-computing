
#!/bin/bash

# 2. Masuk ke folder aplikasi
cd /var/app/stagging

# 3. Tarik variabel environment dari file rahasia Beanstalk
# Ini wajib agar DB_HOST, DB_USER, dll bisa terbaca oleh npm
export $(cat /opt/elasticbeanstalk/deployment/env | xargs)

# 4. Jalankan migrasi
# Gunakan sudo -u webapp jika perlu, tapi biasanya cukup running sebagai root di prebuild
npm run db:migrate
